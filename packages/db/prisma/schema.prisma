// LinkedOut — "LinkedIn for your Ls". See ARCHITECTURE.md + contract.md.
// Boring-wins Postgres. ULID ids (assigned by the client extension in src/ulid.ts).
// One `L` entity + enums. Denormalized counters. Postgres FTS via a tsvector column
// (added in a raw migration — Prisma can't express generated columns).

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum LType {
  L
  WIN
  STORY
  SCAR
  PLOT_TWIST
  CHECKPOINT
  BATTLE
  LESSON
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum ReactionType {
  BEEN_THERE
  HELPFUL
  RESPECT
  PAIN
  SAVED
}

enum JourneyStatus {
  INTERVIEWING
  BUILDING
  WORKING
  STARTING_UP
  RECOVERING
  TAKING_A_BREAK
}

enum NotificationType {
  RELATED
  HELPED
  NEW_FOLLOWER
  COMMENT
}

// ─── User + Auth ──────────────────────────────────────────────────────────────

model User {
  id              String         @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  // Nullable until onboarding completes. A database CHECK rejects empty/whitespace usernames.
  username        String?        @unique
  email           String?        @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  // Stable R2 identity. Public CDN URLs may change; cleanup safety must not.
  avatarObjectKey String?        @unique
  bio             String?
  status          JourneyStatus?

  // Denormalized reputation counters. Updated in the same tx as the triggering write.
  storiesShared      Int @default(0)
  lessonsShared      Int @default(0)
  buildersHelped     Int @default(0)
  lsShared           Int @default(0)
  collectionsCreated Int @default(0)

  // Denormalized social-graph degree. PostgreSQL Follow triggers maintain both
  // sides in the same transaction as each inserted/deleted edge.
  followerCount  Int @default(0)
  followingCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ls              L[]
  reactions       Reaction[]
  comments        Comment[]
  collections     Collection[]
  following       Follow[]         @relation("follower")
  followers       Follow[]         @relation("following")
  notifications   Notification[]   @relation("recipient")
  actorEvents     Notification[]   @relation("actor")
  accounts        Account[]
  sessions        Session[]
  browserSessions BrowserSession[]
  oauthHandoffs   OAuthHandoff[]

  @@index([status])
}

model Account {
  id                String  @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires, id])
}

// Authoritative browser session for the one-origin BFF. The browser holds only the
// random opaque cookie; cookieHash is its one-way lookup identity. The database column
// is named `sid` because that stable identifier is carried by internal API assertions.
model BrowserSession {
  id         String    @id @default(cuid()) @map("sid") // ULID assigned by the client extension
  cookieHash String    @unique @db.Char(64)
  sub        String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [sub], references: [id], onDelete: Cascade)

  @@index([sub])
  @@index([createdAt, id])
  @@index([lastUsedAt, id])
  @@index([revokedAt, id])
}

// One-time OAuth callback result. Only its hash is persisted; sub and returnTo are
// bound by the server after OAuth state validation and cannot be supplied at exchange.
model OAuthHandoff {
  id         String    @id @default(cuid()) // ULID assigned by the client extension
  codeHash   String    @unique @db.Char(64)
  sub        String
  returnTo   String    @db.VarChar(512)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  user User @relation(fields: [sub], references: [id], onDelete: Cascade)

  @@index([sub])
  @@index([expiresAt, id])
  @@index([consumedAt, id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires, token])
}

// Durable two-phase tombstone for avatar deletion. A claimed key can be retried after
// an object-store failure, but can never be attached to a profile again.
model AvatarDeletionClaim {
  key       String    @id
  claimedAt DateTime  @default(now())
  deletedAt DateTime?
  attempts  Int       @default(0)
  lastError String?
  updatedAt DateTime  @updatedAt
}

// ─── L — the core object ──────────────────────────────────────────────────────

model L {
  id       String @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  title String
  story String
  type  LType @default(L)

  visibility  Visibility @default(PUBLIC)
  isAnonymous Boolean    @default(false)

  // Battles are ongoing until resolved.
  resolvedAt DateTime?

  // Denormalized counters — keep feed sorts + card rendering index-only (no COUNT joins).
  reactionCount   Int   @default(0)
  beenThereCount  Int   @default(0)
  helpfulCount    Int   @default(0)
  respectCount    Int   @default(0)
  painCount       Int   @default(0)
  savedCount      Int   @default(0)
  commentCount    Int   @default(0)
  // Lifetime weighted engagement. It has no decay/window, so it is popularity, not trending.
  popularityScore Float @default(0)

  // FTS vector — the GENERATED-ALWAYS tsvector + GIN index are created in a raw migration.
  searchVector Unsupported("tsvector")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions       Reaction[]
  comments        Comment[]
  collectionLs    CollectionL[]
  notifications   Notification[]
  dailySelections DailyLSelection[]

  @@index([visibility, createdAt(sort: Desc)])
  @@index([visibility, id(sort: Desc)])
  @@index([visibility, popularityScore(sort: Desc), id(sort: Desc)])
  @@index([visibility, helpfulCount(sort: Desc), id(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([authorId, id(sort: Desc)])
  @@index([authorId, type])
}

/**
 * Stable winner snapshot for one UTC calendar day.
 */
model DailyLSelection {
  selectedFor      DateTime @id @db.Date
  lId              String?
  l                L?       @relation(fields: [lId], references: [id], onDelete: SetNull)
  interactionCount Int      @default(0)
  selectedAt       DateTime @default(now())

  @@index([lId])
}

// ─── Reactions ────────────────────────────────────────────────────────────────

model Reaction {
  id     String       @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  type   ReactionType
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  l      L            @relation(fields: [lId], references: [id], onDelete: Cascade)
  lId    String

  createdAt DateTime @default(now())

  @@unique([userId, lId, type])
  @@index([lId, type])
  @@index([userId, type, id(sort: Desc)])
  @@index([createdAt, lId, userId])
}

// ─── Comments (threaded) ──────────────────────────────────────────────────────

model Comment {
  id       String @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  body     String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String
  l        L      @relation(fields: [lId], references: [id], onDelete: Cascade)
  lId      String

  parent   Comment?  @relation("thread", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  replies  Comment[] @relation("thread")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The partial (lId, id) WHERE parentId IS NULL pagination index is SQL-owned in
  // 20260714100000_comment_pagination_indexes because Prisma cannot express its predicate.
  @@index([lId, createdAt])
  @@index([parentId, id])
  @@index([createdAt, lId, authorId])
}

// ─── Follow (social graph) ────────────────────────────────────────────────────

model Follow {
  id          String @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  follower    User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  // Both follower/following lists paginate by keyset — `WHERE "followingId" = $1 AND id < $2
  // ORDER BY id DESC` — so `id` must be in the index or Postgres cannot serve the ORDER BY.
  @@index([followingId, id(sort: Desc)])
  @@index([followerId, id(sort: Desc)])
}

// ─── Collections ──────────────────────────────────────────────────────────────

model Collection {
  id        String   @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String
  title     String
  slug      String
  createdAt DateTime @default(now())

  ls CollectionL[]

  @@unique([ownerId, slug])
  @@index([ownerId, id(sort: Desc)])
}

model CollectionL {
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  l            L          @relation(fields: [lId], references: [id], onDelete: Cascade)
  lId          String
  position     Int        @default(0)

  @@id([collectionId, lId])
  @@index([collectionId, position, lId])
  @@index([lId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid()) // ULID (overridden by the client extension; default is a type-level fallback)
  type        NotificationType
  recipient   User             @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String
  actor       User?            @relation("actor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId     String?
  l           L?               @relation(fields: [lId], references: [id], onDelete: Cascade)
  lId         String?
  dedupeKey   String?          @unique
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([recipientId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([recipientId, readAt])
}

// Shared limiter state so all API instances enforce the same buckets.
model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
