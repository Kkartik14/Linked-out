{
  "name": "@linkedout/web",
  "version": "1.1.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "NEXT_PUBLIC_API_BASE_URL=http://localhost:${E2E_API_PORT:-4010}/v1 pnpm build && ALLOW_TEST_DB_RESET=1 TEST_DB_EXPECTED_SESSION_USER=linkedout playwright test",
    "test:e2e:handoff": "NEXT_PUBLIC_API_BASE_URL=/v1 pnpm build && ALLOW_TEST_DB_RESET=1 TEST_DB_EXPECTED_SESSION_USER=linkedout playwright test --config=playwright.handoff.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@linkedout/contracts": "file:../../packages/contracts",
    "@linkedout/internal-auth": "file:../../packages/internal-auth",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/related-projects": "1.1.0",
    "@zxcvbn-ts/core": "4.1.2",
    "@zxcvbn-ts/language-common": "4.1.3",
    "@zxcvbn-ts/language-en": "4.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
