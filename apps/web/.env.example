# Base URL of the LinkedOut backend API (includes the /v1 prefix).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Serve GET /v2/feed/sidebar from a local fixture instead of the network.
#
# The backend has not shipped that route yet (docs/api-contract-v2.md — "backend route
# implementation pending"), so the feed rails have nothing to call. The fixture is parsed
# through feedSidebarResponseSchema at the seam, so it cannot drift from the contract.
#
# Delete this variable, and src/lib/api/fixtures/, once the route is live.
NEXT_PUBLIC_FEED_SIDEBAR_FIXTURE=1
