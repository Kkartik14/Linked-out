# Base URL of the LinkedOut backend API (includes the /v1 prefix).
# Dev default per contract.md §Base URL:
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# When "1", the app serves fixtures from src/lib/api/mocks instead of hitting
# the real backend. Set to "0" (or remove) once the API is running locally.
NEXT_PUBLIC_USE_MOCKS=1
