# Base URL of the LinkedOut backend API (includes the /v1 prefix).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# --- BFF session introspection (ADR 0001 §4.2) — server-only, no NEXT_PUBLIC_ prefix ---
# Session topology. `legacy` = the browser calls Nest directly with lo_access/lo_refresh cookies
# (the current runnable path). `handoff` = the one-origin BFF: the browser holds only lo_sid and
# proxy.ts + the BFF route handlers resolve it. Keep this `legacy` until the full public BFF path
# is deployed and its browser acceptance suite is green. MUST match the API's OAUTH_SESSION_MODE.
OAUTH_SESSION_MODE=legacy
# Canonical browser-facing origin. Required in handoff mode; never derive it from request Host.
WEB_URL=http://localhost:3000
# The private API origin the BFF resolves sessions against. HTTPS is mandatory in production;
# plain HTTP is accepted only for local development/test.
INTERNAL_API_BASE_URL=http://localhost:4000
# Purpose-scoped BFF caller key. MUST match the API's BFF_CALLER_SECRET and MUST NOT match
# INTERNAL_API_SECRET (the latter is Nest-only and can mint user identity). Never expose either.
BFF_CALLER_SECRET=
