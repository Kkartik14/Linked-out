{
  "name": "@linkedout/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "maintenance:cleanup": "node dist/maintenance/run-cleanup.js",
    "lint": "pnpm --workspace-root exec eslint apps/api/src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --workspace-root test:api",
    "test:unit": "pnpm --workspace-root build && pnpm run test:unit:built",
    "test:unit:built": "node ../../scripts/check-unit-test-inventory.cjs && node --test \"test/unit/**/*.test.cjs\"",
    "test:integration": "node --test --test-concurrency=1 test/integration/index.test.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@linkedout/contracts": "workspace:*",
    "@linkedout/db": "workspace:*",
    "@linkedout/internal-auth": "workspace:*",
    "@linkedout/session-authority": "workspace:*",
    "@nestjs/common": "^11.0.5",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.5",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.5",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.7.3"
  }
}
