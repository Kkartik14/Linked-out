# ── Database (packages/db + apps/api) ─────────────────────────────────────────
# Local Docker Postgres (see docker-compose.yml). For Neon, swap in the pooled URL
# for DATABASE_URL and the direct URL for DIRECT_URL.
DATABASE_URL="postgresql://linkedout:linkedout@localhost:5432/linkedout?schema=public"
DIRECT_URL="postgresql://linkedout:linkedout@localhost:5432/linkedout?schema=public"

# ── API server (apps/api) ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_URL=http://localhost:3000
# 0 = direct traffic. Set to the exact trusted proxy hop count in production.
TRUST_PROXY_HOPS=0

# JWT signing secrets (use long random strings in prod; different per environment)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
# Dedicated BFF → private Nest assertion key (at least 32 random bytes; never reuse JWT secrets)
INTERNAL_API_SECRET=
OAUTH_SESSION_MODE=legacy

# Cookie domain — leave empty in dev (host-only cookie on localhost); ".linkedout.app" in prod
COOKIE_DOMAIN=

# ── OAuth providers ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Object storage (Cloudflare R2 / S3) for avatar uploads ────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=linkedout-avatars
R2_PUBLIC_BASE_URL=https://cdn.linkedout.app
# S3-compatible endpoint (R2: https://<account>.r2.cloudflarestorage.com). Leave empty to disable uploads locally.
R2_ENDPOINT=
